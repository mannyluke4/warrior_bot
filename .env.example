# --- Alpaca Paper Keys ---
APCA_API_KEY_ID=your_alpaca_key_here
APCA_API_SECRET_KEY=your_alpaca_secret_here

# --- Data Feed Source ---
WB_DATA_FEED=alpaca              # alpaca | ibkr | databento

# --- Mode ---
WB_MODE=PAPER
WB_ARM_TRADING=1

# --- Entry Mode ---
WB_ENTRY_MODE=pullback          # "direct" = 1-bar entry, "pullback" = classic 3-bar cycle (Ross's actual strategy)

# --- Exit Mode ---
WB_EXIT_MODE=signal             # "signal" = no fixed TP, trail full position; "classic" = core TP + runner trail
WB_BE_TRIGGER_R=3.0             # R-multiple above entry to activate breakeven floor
WB_SIGNAL_TRAIL_PCT=0.99        # Effectively no mechanical trail — let signals handle exits

# --- Re-Entry Cooldown ---
WB_MAX_ENTRIES_PER_SYMBOL=2     # Max entries per symbol before cooldown kicks in
WB_SYMBOL_COOLDOWN_MIN=10       # Minutes to wait after max entries reached

# --- Stock Filtering ---
WB_MIN_FLOAT=0.5                # Min float in millions (blocks micro-float disasters)

# --- Quality Gate ---
WB_QUALITY_MIN_FLOAT=0.5        # Min float at trade time (millions)

# --- Max Loss Safety Net ---
WB_MAX_LOSS_R=2.0               # Force exit if loss exceeds 2R (gap-through protection)

# --- Risk Management ---
WB_RISK_DOLLARS=1000

# --- Quality gate ---
WB_MACD_HARD_GATE=1
WB_MAX_GREEN_1M=5
WB_STALE_STOCK_FILTER=1              # Block ARMs on stocks with dead momentum
WB_STALE_MAX_BARS_NO_HOD=30          # Rolling window: no new high in N bars → stale (handles halt spikes)
WB_STALE_SESSION_HOD_BARS=120        # Session HOD: no new session high in N bars → stale (catches dead oscillating stocks)
WB_STALE_VOL_DECAY_PCT=0             # Volume decay check (0=off). Peak vol from spikes makes normal vol look dead

# --- Exhaustion Filter (prevents late entries on extended stocks) ---
WB_EXHAUSTION_VWAP_PCT=10       # Max % above VWAP before blocking ARM
WB_EXHAUSTION_MOVE_PCT=50       # Max % from session low before blocking ARM
WB_EXHAUSTION_VOL_RATIO=0.4     # Min recent/earlier volume ratio

# --- Dynamic Filter Scaling (scales thresholds for big runners) ---
WB_TREND_STRONG_RANGE_PCT=5        # Session range above this % = big runner, soften DANGER_TREND_DOWN_STRONG
WB_EXHAUSTION_VWAP_RANGE_MULT=0.5  # Effective VWAP% = max(fixed, range% * this)
WB_EXHAUSTION_MOVE_RANGE_MULT=1.5  # Effective move% = max(fixed, range% * this)


# --- Dynamic Market Scanner (Option 3 Hybrid) ---
WB_ENABLE_DYNAMIC_SCANNER=0      # 0=manual watchlist.txt, 1=scan market automatically
WB_SCANNER_MAX_SYMBOLS=500       # Max symbols to scan (after price pre-filter)
WB_SCANNER_WORKERS=10            # Parallel API workers for faster scanning

# --- Stock Filtering (Ross Cameron Criteria) ---
WB_ENABLE_STOCK_FILTERING=1
WB_MIN_GAP_PCT=5
WB_MAX_GAP_PCT=999
WB_PREFERRED_GAP_PCT=20
WB_MAX_FLOAT=20
WB_PREFERRED_MAX_FLOAT=10
WB_MIN_REL_VOLUME=1.5
WB_REQUIRE_EMA_ALIGNMENT=0
WB_MIN_PRICE=2.00
WB_MAX_PRICE=20.00

# --- Sizing Guards ---
WB_MIN_R=0.06
WB_MAX_NOTIONAL=60000
WB_MAX_SHARES=100000
WB_ROUND_LOT=0

# --- Conviction Sizing (Item 5) — scale position size by scanner rank score ---
WB_CONVICTION_SIZING_ENABLED=0   # Master switch (OFF by default)
WB_CONVICTION_BASE_SCORE=0.6     # Rank score that yields 1.0x sizing
WB_CONVICTION_MIN_MULT=0.5       # Floor multiplier (worst-ranked stocks)
WB_CONVICTION_MAX_MULT=2.5       # Ceiling multiplier (best-ranked stocks)
WB_CONVICTION_SCALE_NOTIONAL=1   # Also scale MAX_NOTIONAL with conviction (0=cap stays flat)

# --- Core/Runner split (THIS is what your code uses) ---
WB_SCALE_CORE=0.65

# --- Core profit lock (your universal exit engine) ---
WB_CORE_TP_R=1.00
WB_TP_FUZZ=0.03

# --- Break-even protection ---
WB_BE_OFFSET=0.01

# --- Runner trail ---
WB_RUNNER_TRAIL_R=1.00

# --- Bearish engulf exit ---
WB_EXIT_ON_BEAR_ENGULF=1
WB_BE_PARABOLIC_GRACE=1              # Suppress BE exits during parabolic ramps (new highs + in profit)
WB_BE_GRACE_MIN_R=1.0                # Only suppress if price > entry + N*R
WB_BE_GRACE_MIN_NEW_HIGHS=3          # Need N+ new highs in lookback window to suppress
WB_BE_GRACE_LOOKBACK_BARS=6          # 10s bars to look back (6 = 60 seconds)
WB_BE_GRACE_MIN=0                    # Minutes after entry before BE can exit (0=off, risky due to butterfly effects on VERO-style cascades)

# --- Topping wicky exit ---
WB_EXIT_ON_TOPPING_WICKY=1
WB_TOPPING_WICKY_GRACE_MIN=3  # Minutes after entry before topping wicky can exit (breakout volatility grace)

# --- Quote-aware execution ---
WB_USE_QUOTES_FOR_LIMITS=1
WB_ENTRY_QUOTE_PAD=0.00
WB_EXIT_QUOTE_PAD=0.00
WB_ENTRY_INITIAL_WIGGLE=0.01
WB_EXIT_INITIAL_WIGGLE=0.03
WB_ENTRY_MAX_SPREAD_PCT=5.0     # Max bid-ask spread as % of mid. Skip entry if wider.
WB_ENTRY_MAX_BID_DEV_PCT=5.0    # Max bid deviation from last trade %. Skip if quotes are phantom.

# --- Entry: limit + chase ---
WB_LIMIT_OFFSET_BUY=0.00
WB_ENTRY_TIMEOUT_SEC=30
WB_ENTRY_CHASE_STEP=0.05
WB_ENTRY_MAX_CHASE=0.15
WB_ENTRY_MAX_ATTEMPTS=3
WB_LIMIT_OFFSET_SELL=0.01
WB_EXIT_TIMEOUT_SEC=20
WB_EXIT_CHASE_STEP=0.02
WB_EXIT_MAX_CHASE=0.40
WB_EXIT_MAX_ATTEMPTS=4
WB_EXIT_STOP_FLOOR_PAD=0.02

# Percentage-based exit offsets (override fixed-cent values above if > 0)
WB_EXIT_INITIAL_WIGGLE_PCT=0.3   # 0.3% of ref price (~1.5¢ on $5 stock). Set 0 to use fixed WB_EXIT_INITIAL_WIGGLE
WB_LIMIT_OFFSET_SELL_PCT=0.1     # 0.1% of ref price (~0.5¢ on $5 stock). Set 0 to use fixed WB_LIMIT_OFFSET_SELL
WB_EXIT_CHASE_STEP_PCT=0.2       # 0.2% step when chasing (~1¢ on $5 stock). Set 0 to use fixed WB_EXIT_CHASE_STEP
WB_EXIT_MAX_CHASE_PCT=3.0        # 3% max total chase (~15¢ on $5 stock). Set 0 to use fixed WB_EXIT_MAX_CHASE


# --- Take profit (used for plan.take_profit computation) ---
WB_TAKE_PROFIT_R=1.00

DATABENTO_API_KEY=your_databento_key_here

# --- Console noise controls ---
WB_PRINT_PATTERNS=0
WB_PRINT_BAR_SIGNALS=1
WB_PRINT_ARMED_ONLY=1

# --- Data health ---
WB_STALE_TRADE_SEC=15
WB_STALE_QUOTE_SEC=15

# --- Pending safety (optional clarity) ---
WB_PENDING_TIMEOUT_SEC=45


# --- Feature 5: Post-Halt Sizing Override ---
WB_HALT_SIZING_OVERRIDE=0               # 0=off, 1=on. Tightens stop after circuit breaker halts
WB_HALT_RANGE_MULT=5.0                  # Bar range > N * avg = halt detected
WB_HALT_STOP_ATR_MULT=2.5               # Override stop = entry - (mult * avg_range)
WB_HALT_PERSIST_BARS=5                   # Halt flag persists N bars after detection

# --- Volatility Floor (wider stops on volatile stocks) ---
WB_VOL_FLOOR_ENABLED=0                  # 0=off, 1=on. Widens stop when R < stock's volatility
WB_VOL_FLOOR_ATR_MULT=1.5               # Min stop distance = mult * avg_bar_range (last 14 bars)
WB_VOL_FLOOR_PCT=0                       # Min stop as % of entry price (e.g., 5 = 5%). 0=disabled

# --- Bail Timer (exit if not profitable within N minutes) ---
WB_BAIL_TIMER_ENABLED=1
WB_BAIL_TIMER_MINUTES=5

# --- Daily Risk Management ---
WB_DAILY_GOAL=500
WB_MAX_DAILY_LOSS=500
WB_GIVEBACK_HARD_PCT=50          # Walk away if give back 50% of peak daily P&L
WB_GIVEBACK_WARN_PCT=20          # Halve risk if give back 20% of peak daily P&L
WB_MAX_CONSECUTIVE_LOSSES=3      # Stop trading after 3 consecutive losses

# --- Warmup Sizing (start small, scale up) ---
WB_WARMUP_SIZE_PCT=25            # Use 25% of risk until daily P&L crosses threshold
WB_WARMUP_SIZE_THRESHOLD=500     # After this much daily profit, use full size

# --- Squeeze vol-baseline winsorization (added 2026-04-14) ---
# When a single extreme bar (e.g. ROLR's 22.7x spike) enters the rolling
# avg_vol, it poisons the baseline so subsequent bars never re-PRIME. Cap
# each bar's contribution to the baseline at WINSORIZE_CAP × the current avg.
# Eligibility check (bar.v >= avg_vol × VOL_MULT) still uses raw v.
WB_SQ_VOL_WINSORIZE_ENABLED=0    # default 0 — gated off until validated
WB_SQ_VOL_WINSORIZE_CAP=5.0      # max multiple of current avg a bar can contribute

# --- Squeeze seed-staleness arm validation (added 2026-04-13) ---
# Drops arms that are already far behind current price when seed replay ends —
# fixes the "stale PM-low trigger fires on live ticks" bug (e.g. SKYQ 2026-04-13
# where a $16.02 arm fired while stock was $17.36). Complements WB_SEED_GATE.
WB_SQ_SEED_STALE_GATE_ENABLED=1  # 1=ON. Correctness fix; set 0 only for clean regression diff.
WB_SQ_SEED_STALE_PCT=2.0         # Drop arm if current_price > trigger_high * (1 + 2%)

# ────────────────────────────────────────────────────────────────────
# WAVE BREAKOUT (Stage 3 — DIRECTIVE_WAVE_BREAKOUT_STAGE3_BUILD.md)
# Strategy validated by 2026-05-04 Stage 1 + Stage 2 research:
#   wave_research/v8b_v2_pyramid/  — 648 trades / 53.4% WR / PF 2.01
# Default OFF; flip to 1 only after Phase 1 paper validation passes.
# ────────────────────────────────────────────────────────────────────

# Master switch
WB_WAVE_BREAKOUT_ENABLED=0

# Wave detection (proven in research; do NOT change without re-running census)
WB_WB_MIN_WAVE_PCT=0.0075         # 0.75% minimum wave magnitude
WB_WB_WAVE_MIN_DURATION_MIN=3     # waves shorter than this are noise
WB_WB_WAVE_MAX_DURATION_MIN=15    # waves longer than this are trends, not chops
WB_WB_REVERSAL_CONFIRM_PCT=0.005  # 0.5% reversal required to confirm wave end

# Setup scoring threshold (V8b uses 7)
WB_WB_MIN_SCORE=7                 # minimum score for ARMED state

# Position sizing — EQUITY-PERCENT (matches squeeze for compounding)
WB_WB_RISK_PCT=0.025              # 2.5% of current equity per trade
WB_WB_RISK_FLOOR_DOLLARS=500      # don't risk less than $500 even on small equity
WB_WB_RISK_CEILING_DOLLARS=5000   # don't risk more than $5K even on large equity
WB_WB_MIN_RISK_PER_SHARE=0.01     # absolute floor (V0 sizer hardening)
WB_WB_MIN_RISK_PCT=0.001          # 10 bps of entry price floor (V0 hardening)
WB_WB_MAX_NOTIONAL=50000          # binding notional cap (per-trade)
WB_WB_STOP_BUFFER_PCT=0.25        # stop is N% below bounce-bar low

# Exit logic (V2 trailing-only — Stage 2 winner)
WB_WB_TRAILING_ACTIVATE_R=1.0     # trail activates at +1R
WB_WB_TRAILING_DISTANCE_R=0.5     # trail at 0.5R below running peak
WB_WB_HARD_STOP_R=1.0             # initial stop at -1R below entry
WB_WB_NO_TIME_STOP=1              # no time cap (research finding: time stops cut runners)
WB_WB_SESSION_END_FORCE_EXIT=1    # exit any open WB position at window close

# Pyramid (V5 — adds modest +$6K combined with V2)
WB_WB_PYRAMID_ENABLED=1
WB_WB_PYRAMID_TRIGGER_R=1.0       # add second leg when +1R reached
WB_WB_PYRAMID_RISK_PCT=0.025      # second leg uses same equity-percent

# Portfolio concurrency (V7 — realistic operating constraint)
WB_WB_MAX_CONCURRENT=3            # max simultaneous WB positions across symbols
