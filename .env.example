# --- Alpaca Paper Keys ---
APCA_API_KEY_ID=your_alpaca_key_here
APCA_API_SECRET_KEY=your_alpaca_secret_here

# --- Data Feed Source ---
WB_DATA_FEED=alpaca              # alpaca | ibkr | databento

# --- Mode ---
WB_MODE=PAPER
WB_ARM_TRADING=1

# --- Entry Mode ---
WB_ENTRY_MODE=direct            # "direct" = 1-bar entry, "pullback" = classic 3-bar cycle

# --- Exit Mode ---
WB_EXIT_MODE=signal             # "signal" = no fixed TP, trail full position; "classic" = core TP + runner trail
WB_BE_TRIGGER_R=3.0             # R-multiple above entry to activate breakeven floor
WB_SIGNAL_TRAIL_PCT=0.99        # Effectively no mechanical trail — let signals handle exits

# --- Re-Entry Cooldown ---
WB_MAX_ENTRIES_PER_SYMBOL=2     # Max entries per symbol before cooldown kicks in
WB_SYMBOL_COOLDOWN_MIN=10       # Minutes to wait after max entries reached

# --- Stock Filtering ---
WB_MIN_FLOAT=0.5                # Min float in millions (blocks micro-float disasters)

# --- Quality Gate ---
WB_QUALITY_MIN_FLOAT=0.5        # Min float at trade time (millions)

# --- Max Loss Safety Net ---
WB_MAX_LOSS_R=2.0               # Force exit if loss exceeds 2R (gap-through protection)

# --- Risk Management ---
WB_RISK_DOLLARS=1000

# --- Scoring / quality gate ---
WB_USE_SCORING=0
WB_MIN_SCORE=3
WB_MAX_SCORE=6                  # Cap at 6 — high scores = late entries that lose money
WB_MACD_HARD_GATE=1
WB_MAX_GREEN_1M=5
WB_STALE_STOCK_FILTER=1              # Block ARMs on stocks with dead momentum
WB_STALE_MAX_BARS_NO_HOD=30          # Rolling window: no new high in N bars → stale (handles halt spikes)
WB_STALE_SESSION_HOD_BARS=120        # Session HOD: no new session high in N bars → stale (catches dead oscillating stocks)
WB_STALE_VOL_DECAY_PCT=0             # Volume decay check (0=off). Peak vol from spikes makes normal vol look dead

# --- Exhaustion Filter (prevents late entries on extended stocks) ---
WB_EXHAUSTION_VWAP_PCT=10       # Max % above VWAP before blocking ARM
WB_EXHAUSTION_MOVE_PCT=50       # Max % from session low before blocking ARM
WB_EXHAUSTION_VOL_RATIO=0.4     # Min recent/earlier volume ratio

# --- Dynamic Filter Scaling (scales thresholds for big runners) ---
WB_TREND_STRONG_RANGE_PCT=5        # Session range above this % = big runner, soften DANGER_TREND_DOWN_STRONG
WB_EXHAUSTION_VWAP_RANGE_MULT=0.5  # Effective VWAP% = max(fixed, range% * this)
WB_EXHAUSTION_MOVE_RANGE_MULT=1.5  # Effective move% = max(fixed, range% * this)

# --- Gap and Go Strategy ---
WB_ENABLE_GAP_AND_GO=0
WB_GAP_AND_GO_MIN_SCORE=4

# --- Dynamic Market Scanner (Option 3 Hybrid) ---
WB_ENABLE_DYNAMIC_SCANNER=0      # 0=manual watchlist.txt, 1=scan market automatically
WB_SCANNER_MAX_SYMBOLS=500       # Max symbols to scan (after price pre-filter)
WB_SCANNER_WORKERS=10            # Parallel API workers for faster scanning

# --- Stock Filtering (Ross Cameron Criteria) ---
WB_ENABLE_STOCK_FILTERING=1
WB_MIN_GAP_PCT=5
WB_PREFERRED_GAP_PCT=20
WB_MAX_FLOAT=50
WB_PREFERRED_MAX_FLOAT=10
WB_MIN_REL_VOLUME=1.5
WB_REQUIRE_EMA_ALIGNMENT=0
WB_MIN_PRICE=1.00
WB_MAX_PRICE=20.00

# --- Sizing Guards ---
WB_MIN_R=0.06
WB_MAX_NOTIONAL=60000
WB_MAX_SHARES=100000
WB_ROUND_LOT=0

# --- Core/Runner split (THIS is what your code uses) ---
WB_SCALE_CORE=0.65

# --- Core profit lock (your universal exit engine) ---
WB_CORE_TP_R=1.00
WB_TP_FUZZ=0.03

# --- Break-even protection ---
WB_BE_OFFSET=0.01

# --- Runner trail ---
WB_RUNNER_TRAIL_R=1.00

# --- Bearish engulf exit ---
WB_EXIT_ON_BEAR_ENGULF=1
WB_BE_PARABOLIC_GRACE=1              # Suppress BE exits during parabolic ramps (new highs + in profit)
WB_BE_GRACE_MIN_R=1.0                # Only suppress if price > entry + N*R
WB_BE_GRACE_MIN_NEW_HIGHS=3          # Need N+ new highs in lookback window to suppress
WB_BE_GRACE_LOOKBACK_BARS=6          # 10s bars to look back (6 = 60 seconds)
WB_BE_GRACE_MIN=0                    # Minutes after entry before BE can exit (0=off, risky due to butterfly effects on VERO-style cascades)

# --- Topping wicky exit ---
WB_EXIT_ON_TOPPING_WICKY=1
WB_TOPPING_WICKY_GRACE_MIN=3  # Minutes after entry before topping wicky can exit (breakout volatility grace)

# --- Quote-aware execution ---
WB_USE_QUOTES_FOR_LIMITS=1
WB_ENTRY_QUOTE_PAD=0.00
WB_EXIT_QUOTE_PAD=0.00
WB_ENTRY_INITIAL_WIGGLE=0.01
WB_EXIT_INITIAL_WIGGLE=0.03
WB_ENTRY_MAX_SPREAD_PCT=5.0     # Max bid-ask spread as % of mid. Skip entry if wider.
WB_ENTRY_MAX_BID_DEV_PCT=5.0    # Max bid deviation from last trade %. Skip if quotes are phantom.

# --- Entry: limit + chase ---
WB_LIMIT_OFFSET_BUY=0.00
WB_ENTRY_TIMEOUT_SEC=30
WB_ENTRY_CHASE_STEP=0.05
WB_ENTRY_MAX_CHASE=0.15
WB_ENTRY_MAX_ATTEMPTS=3
WB_LIMIT_OFFSET_SELL=0.01
WB_EXIT_TIMEOUT_SEC=20
WB_EXIT_CHASE_STEP=0.02
WB_EXIT_MAX_CHASE=0.40
WB_EXIT_MAX_ATTEMPTS=4
WB_EXIT_STOP_FLOOR_PAD=0.02

# Percentage-based exit offsets (override fixed-cent values above if > 0)
WB_EXIT_INITIAL_WIGGLE_PCT=0.3   # 0.3% of ref price (~1.5¢ on $5 stock). Set 0 to use fixed WB_EXIT_INITIAL_WIGGLE
WB_LIMIT_OFFSET_SELL_PCT=0.1     # 0.1% of ref price (~0.5¢ on $5 stock). Set 0 to use fixed WB_LIMIT_OFFSET_SELL
WB_EXIT_CHASE_STEP_PCT=0.2       # 0.2% step when chasing (~1¢ on $5 stock). Set 0 to use fixed WB_EXIT_CHASE_STEP
WB_EXIT_MAX_CHASE_PCT=3.0        # 3% max total chase (~15¢ on $5 stock). Set 0 to use fixed WB_EXIT_MAX_CHASE


# --- Take profit (used for plan.take_profit computation) ---
WB_TAKE_PROFIT_R=1.00

# --- Level 2 (Order Book) ---
WB_ENABLE_L2=0                    # 0=off, 1=on (requires IBKR running for live)
WB_IBKR_HOST=127.0.0.1
WB_IBKR_PORT=7497
WB_IBKR_CLIENT_ID=1
WB_L2_IMBALANCE_BULL=0.65        # Ratio above this = bullish signal
WB_L2_IMBALANCE_BEAR=0.35        # Ratio below this = bearish signal
WB_L2_STACK_MULTIPLIER=3.0       # Level size > Nx average = stacking
WB_L2_SPREAD_WARN=1.0            # Spread > X% = wide spread penalty
DATABENTO_API_KEY=your_databento_key_here

# --- Console noise controls ---
WB_PRINT_PATTERNS=0
WB_PRINT_BAR_SIGNALS=1
WB_PRINT_ARMED_ONLY=1

# --- Data health ---
WB_STALE_TRADE_SEC=15
WB_STALE_QUOTE_SEC=15

# --- Pending safety (optional clarity) ---
WB_PENDING_TIMEOUT_SEC=45

# ═══════════════════════════════════════════════════
# NEW ALGORITHMIC FEATURES (default OFF)
# ═══════════════════════════════════════════════════

# --- Feature 1: LevelMap (Resistance Tracking + Entry Gate) ---
WB_LEVEL_MAP_ENABLED=0           # 0=off, 1=on. Blocks entries near failed resistance levels
WB_LEVEL_MIN_FAILS=1             # Min rejection count before level blocks entry (was 2)
WB_LEVEL_ZONE_WIDTH_PCT=2.0      # Zone width as % of price (2% = 12¢ on $6 stock, clusters LCFY/ACON)
WB_LEVEL_BREAK_CONFIRM_BARS=2    # Consecutive closes above level to confirm break

# --- Feature 2: 3-Tranche Exit Scaling ---
WB_3TRANCHE_ENABLED=0            # 0=off (2-part core/runner), 1=on (3-part T1/T2/T3). Forces classic exit mode.
WB_SCALE_T1=0.40                 # T1 = 40% of position. Exit at 1R.
WB_SCALE_T2=0.35                 # T2 = 35% of position. Exit at 2R.
WB_T1_TP_R=1.0                   # T1 take profit in R-multiples
WB_T2_TP_R=2.0                   # T2 take profit in R-multiples
WB_T2_STOP_LOCK_R=0.5            # After T2 hit, lock stop at entry + 0.5R

# --- Feature 3: Parabolic Regime Detector ---
WB_PARABOLIC_REGIME_ENABLED=0    # 0=off (legacy grace), 1=on (multi-signal detector)
WB_PARABOLIC_MIN_NEW_HIGHS=3     # Consecutive new highs to count as 1 signal
WB_PARABOLIC_CHANDELIER_MULT=2.5 # Chandelier stop = peak - (mult * ATR)
WB_PARABOLIC_MIN_HOLD_BARS=6     # Min bars to suppress exits during parabolic (6 x 10s = 60s)
WB_PARABOLIC_MIN_HOLD_BARS_NORMAL=3  # Min bars after entry before pattern exits (3 x 10s = 30s)

# --- Feature 4: Conviction Floor (Trap Stock Filter) ---
WB_CONVICTION_FLOOR=0                   # 0=off, 1=on. Blocks weak entries: score<6, no tags, tiny gap
WB_CONVICTION_FLOOR_MIN_SCORE=6.0       # Score threshold
WB_CONVICTION_FLOOR_MIN_GAP_PCT=1.0     # Absolute gap threshold (%)
WB_CONVICTION_FLOOR_MIN_BARS=15         # Skip filter for first N bars (Profile A enters early)

# --- Feature 5: Post-Halt Sizing Override ---
WB_HALT_SIZING_OVERRIDE=0               # 0=off, 1=on. Tightens stop after circuit breaker halts
WB_HALT_RANGE_MULT=5.0                  # Bar range > N * avg = halt detected
WB_HALT_STOP_ATR_MULT=2.5               # Override stop = entry - (mult * avg_range)
WB_HALT_PERSIST_BARS=5                   # Halt flag persists N bars after detection
